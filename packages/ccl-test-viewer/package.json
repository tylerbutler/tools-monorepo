{
	"name": "@tylerbu/ccl-test-viewer",
	"version": "0.1.0",
	"description": "CCL Test Suite Viewer - Interactive test result visualization",
	"keywords": [
		"ccl",
		"test",
		"viewer",
		"sveltekit"
	],
	"homepage": "https://github.com/tylerbutler/tools-monorepo/tree/main/packages/ccl-test-viewer#readme",
	"bugs": "https://github.com/tylerbutler/tools-monorepo/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tylerbutler/tools-monorepo.git",
		"directory": "packages/ccl-test-viewer"
	},
	"license": "MIT",
	"author": "Tyler Butler <tyler@tylerbutler.com>",
	"type": "module",
	"scripts": {
		"build": "npm run sync-data && vite build",
		"check": "npm run check:svelte && npm run check:format",
		"check:format": "biome check . --linter-enabled=false",
		"check:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"dev": "vite dev",
		"format": "biome check . --linter-enabled=false --write",
		"lint": "biome lint .",
		"lint:fix": "biome lint . --write",
		"preview": "vite preview",
		"sync": "svelte-kit sync",
		"sync-data": "tsx scripts/sync-data.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:debug": "playwright test --debug",
		"test:all": "npm run test && npm run test:e2e",
		"perf:bundle": "npm run build && open .sonda/index.html",
		"perf:lighthouse": "npm run build && lhci autorun",
		"perf:stats": "node scripts/bundle-stats.js"
	},
	"dependencies": {
		"@hugeicons/core-free-icons": "^1.0.17",
		"@hugeicons/svelte": "^1.0.2",
		"@tailwindcss/typography": "^0.5.16",
		"chart.js": "^4.4.7",
		"clsx": "^2.1.1",
		"prismjs": "^1.29.0",
		"tailwind-merge": "^2.6.0",
		"tailwind-variants": "^0.2.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.0.4",
		"@lhci/cli": "^0.13.0",
		"@playwright/test": "^1.55.0",
		"@sveltejs/adapter-static": "^3.0.6",
		"@sveltejs/kit": "^2.9.1",
		"@sveltejs/vite-plugin-svelte": "^4.0.2",
		"@tailwindcss/forms": "^0.5.9",
		"@testing-library/svelte": "^5.2.6",
		"@types/node": "^20.12.7",
		"@types/prismjs": "^1.26.5",
		"@vitest/coverage-v8": "^3.0.4",
		"@vitest/ui": "^3.0.4",
		"autoprefixer": "^10.4.20",
		"jsdom": "^25.0.1",
		"playwright": "^1.55.0",
		"postcss": "^8.5.0",
		"sonda": "^0.9.0",
		"sort-package-json": "*",
		"svelte": "^5.8.9",
		"svelte-check": "^4.3.1",
		"tailwindcss": "^3.4.15",
		"tslib": "^2.8.1",
		"tsx": "^4.20.3",
		"typescript": "~5.5.4",
		"vite": "^6.0.7",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^3.0.4"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
