{
	"name": "@tylerbu/sail",
	"version": "0.0.1",
	"private": true,
	"description": "Come sail away.",
	"keywords": ["build"],
	"homepage": "https://github.com/tylerbutler/tools-monorepo/packages/sail/",
	"bugs": "https://github.com/tylerbutler/tools-monorepo/issues",
	"repository": {
		"type": "git",
		"url": "https://github.com/tylerbutler/tools-monorepo.git",
		"directory": "packages/sail"
	},
	"license": "MIT",
	"author": "Tyler Butler <tyler@tylerbutler.com>",
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./esm/index.d.ts",
				"default": "./esm/index.js"
			}
		}
	},
	"types": "esm/index.d.ts",
	"bin": {
		"sail": "./bin/run.js"
	},
	"files": ["/bin", "/esm", "/oclif.manifest.json"],
	"scripts": {
		"build": "fluid-build . --task build",
		"check": "npm run check:format",
		"check:format": "biome format .",
		"clean": "concurrently npm:clean:build npm:clean:manifest",
		"clean:build": "rimraf esm *.tsbuildinfo",
		"clean:manifest": "rimraf oclif.manifest.json",
		"compile": "tsc --project ./tsconfig.json",
		"format": "sort-package-json && biome format --write .",
		"full": "fluid-build . --task full",
		"lint": "biome lint .",
		"lint:fix": "biome lint . --apply",
		"manifest": "oclif manifest",
		"postpack": "npm run clean:manifest",
		"readme": "oclif readme --multi",
		"sort-package-json": "sort-package-json",
		"test:mocha": "mocha --forbid-only \"test/**/*.test.ts\""
	},
	"oclif": {
		"additionalHelpFlags": ["-h"],
		"additionalVersionFlags": ["-V"],
		"bin": "sail",
		"commands": "./esm/commands",
		"dirname": "sail-cli",
		"plugins": [
			"@oclif/plugin-help",
			"@oclif/plugin-autocomplete",
			"@oclif/plugin-warn-if-update-available"
		],
		"repositoryPrefix": "<%- repo %>/blob/main/packages/sail/<%- commandPath %>",
		"topicSeparator": " ",
		"topics": {}
	},
	"dependencies": {
		"@fluid-tools/build-cli": "^0.38.0",
		"@fluidframework/build-tools": "^0.40.0",
		"@oclif/core": "^4.0.4",
		"@oclif/plugin-autocomplete": "^3.1.2",
		"@oclif/plugin-help": "^6.2.1",
		"@oclif/plugin-plugins": "^5.2.4",
		"@oclif/plugin-warn-if-update-available": "^3.1.5",
		"@tylerbu/cli-api": "workspace:^",
		"chalk": "^5.3.0",
		"concurrently": "^8.2.2",
		"debug": "^4.3.4",
		"simple-git": "^3.24.0",
		"strip-ansi": "^7.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "1.8.3",
		"@oclif/test": "^4.0.3",
		"@types/async": "^3.2.24",
		"@types/chai": "^4.3.16",
		"@types/debug": "^4.1.12",
		"@types/mocha": "^10.0.6",
		"@types/node": "^20.12.7",
		"chai": "^4.4.1",
		"mocha": "^10.4.0",
		"oclif": "^4.13.5",
		"rimraf": "^6.0.0",
		"sort-package-json": "2.10.0",
		"ts-node": "^10.9.2",
		"tslib": "^2.6.2",
		"type-fest": "^4.18.2",
		"typescript": "~5.5.0"
	},
	"packageManager": "pnpm@9.5.0+sha256.dbdf5961c32909fb030595a9daa1dae720162e658609a8f92f2fa99835510ca5",
	"engines": {
		"node": ">=18.0.0"
	}
}
