{
  "name": "ccl",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_item"
      }
    },
    "_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "entry"
        },
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "PATTERN",
          "value": "\\r?\\n"
        }
      ]
    },
    "entry": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "single_line_key"
            },
            {
              "type": "SYMBOL",
              "name": "assignment"
            },
            {
              "type": "SYMBOL",
              "name": "_value"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "multiline_key"
            },
            {
              "type": "SYMBOL",
              "name": "assignment"
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "single_line_value"
                },
                {
                  "type": "PATTERN",
                  "value": "\\r?\\n"
                }
              ]
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "assignment"
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "single_line_value"
                },
                {
                  "type": "PATTERN",
                  "value": "\\r?\\n"
                }
              ]
            }
          ]
        }
      ]
    },
    "single_line_key": {
      "type": "PATTERN",
      "value": "[^\\s=\\n\\/][^\\n\\r=]*"
    },
    "multiline_key": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "single_line_key"
        },
        {
          "type": "PATTERN",
          "value": "\\r?\\n"
        },
        {
          "type": "SYMBOL",
          "name": "key_continuation"
        }
      ]
    },
    "key_continuation": {
      "type": "PATTERN",
      "value": "[^\\n\\r=]+"
    },
    "assignment": {
      "type": "STRING",
      "value": "="
    },
    "_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "PATTERN",
              "value": "\\r?\\n"
            },
            {
              "type": "SYMBOL",
              "name": "multiline_value"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "single_line_value"
            },
            {
              "type": "PATTERN",
              "value": "\\r?\\n"
            }
          ]
        }
      ]
    },
    "single_line_value": {
      "type": "PATTERN",
      "value": "[^\\n\\r]*"
    },
    "multiline_value": {
      "type": "REPEAT1",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "indent"
          },
          {
            "type": "SYMBOL",
            "name": "value_line"
          },
          {
            "type": "PATTERN",
            "value": "\\r?\\n"
          }
        ]
      }
    },
    "value_line": {
      "type": "PATTERN",
      "value": "[^\\n\\r]*"
    },
    "indent": {
      "type": "PATTERN",
      "value": "[ \\t]+"
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "marker"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment_text"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\r?\\n"
        }
      ]
    },
    "marker": {
      "type": "STRING",
      "value": "/="
    },
    "comment_text": {
      "type": "PATTERN",
      "value": "[ ][^\\n\\r]*"
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": []
